# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set base directory
    RewriteBase /
    
    # Skip if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Route all requests to index.php
    RewriteRule ^api/(.*)$ public/index.php [QSA,L]
</IfModule>